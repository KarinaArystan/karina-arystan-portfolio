---
const currentPath = Astro.url.pathname;
const isPortfolioPage = currentPath.startsWith('/brands') || currentPath.startsWith('/web') || currentPath.startsWith('/content');
---

<header
  class="fixed top-0 left-0 right-0 z-50 pb-8 transition-all duration-300"
  id="site-nav"
>
  <!-- Faded backdrop: solid at top, transparent at bottom -->
  <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to bottom, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0) 100%); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); mask-image: linear-gradient(to bottom, black 0%, black 40%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 0%, black 40%, transparent 100%);"></div>
  <nav class="relative mx-auto flex max-w-7xl items-center justify-between px-6 py-5 lg:px-12">
    <!-- Logo -->
    <a href="/" class="nav-logo transition-all duration-300">
      <img
        src="/images/favicon.png"
        alt="Karina Arystan"
        class="h-9 w-auto md:h-10 brightness-0 invert"
      />
    </a>

    <!-- Desktop Nav Links -->
    <div class="hidden items-center gap-8 md:flex">
      <!-- Portfolio dropdown -->
      <div class="group relative" id="portfolio-dropdown">
        <button
          class:list={[
            'flex items-center gap-1 text-sm font-medium tracking-wide uppercase transition-colors hover:text-terracotta',
            isPortfolioPage ? 'text-terracotta' : 'text-cream',
          ]}
          type="button"
        >
          Portfolio
          <svg class="h-3.5 w-3.5 transition-transform group-hover:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <div class="invisible absolute left-1/2 top-full z-50 min-w-[200px] -translate-x-1/2 pt-3 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100" id="portfolio-menu">
          <div class="overflow-hidden rounded-xl bg-charcoal/95 shadow-xl backdrop-blur-md">
            <a href="/content" class="block px-5 py-3 text-sm font-medium text-cream/80 transition-colors hover:bg-white/10 hover:text-cream">Content Creation</a>
            <a href="/brands" class="block px-5 py-3 text-sm font-medium text-cream/80 transition-colors hover:bg-white/10 hover:text-cream">Brand Development</a>
            <a href="/web" class="block px-5 py-3 text-sm font-medium text-cream/80 transition-colors hover:bg-white/10 hover:text-cream">Web Design</a>
          </div>
        </div>
      </div>
      <a
        href="/about"
        class:list={[
          'text-sm font-medium tracking-wide uppercase transition-colors hover:text-terracotta',
          currentPath === '/about' ? 'text-terracotta' : 'text-cream',
        ]}
      >
        About
      </a>
      <a
        href="/#contact"
        class="rounded-full bg-cream px-5 py-2 text-sm font-medium uppercase tracking-wide text-charcoal transition-all hover:bg-terracotta hover:text-cream"
      >
        Contact
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      class="flex flex-col gap-1.5 md:hidden"
      id="menu-toggle"
      aria-label="Toggle menu"
    >
      <span class="block h-0.5 w-6 bg-cream transition-transform" id="menu-line-1"></span>
      <span class="block h-0.5 w-6 bg-cream transition-opacity" id="menu-line-2"></span>
      <span class="block h-0.5 w-6 bg-cream transition-transform" id="menu-line-3"></span>
    </button>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div
    class="fixed inset-0 z-40 hidden flex-col items-center justify-between pt-8 pb-10 bg-cream/98 backdrop-blur-sm"
    id="mobile-menu"
  >
    <!-- Close button -->
    <button
      class="absolute top-6 right-6 flex h-10 w-10 items-center justify-center text-charcoal transition-colors hover:text-terracotta"
      id="menu-close"
      aria-label="Close menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>

    <!-- Favicon decoration -->
    <div class="px-8 pt-2 pb-4">
      <img src="/images/favicon.png" alt="" class="mx-auto h-20 w-auto" />
    </div>

    <!-- Nav links (centered in remaining space) -->
    <div class="flex flex-1 flex-col items-center justify-center gap-7">
      <a href="/" class="font-subheading text-3xl uppercase tracking-wide text-charcoal transition-colors hover:text-terracotta" data-mobile-link>
        Home
      </a>

      <!-- Portfolio dropdown -->
      <div class="flex flex-col items-center">
        <button
          class="flex items-center gap-2 font-subheading text-3xl uppercase tracking-wide text-charcoal transition-colors hover:text-terracotta"
          id="mobile-portfolio-toggle"
          type="button"
        >
          Portfolio
          <svg class="h-5 w-5 transition-transform duration-200" id="mobile-portfolio-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <div class="hidden flex-col items-center gap-3 pt-4" id="mobile-portfolio-submenu">
          <a href="/content" class="font-subheading text-xl uppercase tracking-wide text-warm-gray transition-colors hover:text-terracotta" data-mobile-link>Content Creation</a>
          <a href="/brands" class="font-subheading text-xl uppercase tracking-wide text-warm-gray transition-colors hover:text-terracotta" data-mobile-link>Brand Development</a>
          <a href="/web" class="font-subheading text-xl uppercase tracking-wide text-warm-gray transition-colors hover:text-terracotta" data-mobile-link>Web Design</a>
        </div>
      </div>

      <a href="/about" class="font-subheading text-3xl uppercase tracking-wide text-charcoal transition-colors hover:text-terracotta" data-mobile-link>
        About
      </a>

      <!-- Contact pill -->
      <a href="/#contact" class="rounded-full bg-terra px-8 py-3 font-subheading text-xl uppercase tracking-wide text-cream transition-all hover:bg-charcoal" data-mobile-link>
        Contact
      </a>
    </div>

    <!-- Social icons in terra circles -->
    <div class="flex items-center justify-center gap-5 pt-6 pb-2">
      <a href="https://www.instagram.com/customgraphicnovels/" target="_blank" rel="noopener noreferrer" class="flex h-11 w-11 items-center justify-center rounded-full bg-terra text-cream transition-colors hover:bg-charcoal" aria-label="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
      </a>
      <a href="https://www.linkedin.com/in/karina-arystan/" target="_blank" rel="noopener noreferrer" class="flex h-11 w-11 items-center justify-center rounded-full bg-terra text-cream transition-colors hover:bg-charcoal" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
      </a>
      <a href="https://www.tiktok.com/@customgraphicnovels.com" target="_blank" rel="noopener noreferrer" class="flex h-11 w-11 items-center justify-center rounded-full bg-terra text-cream transition-colors hover:bg-charcoal" aria-label="TikTok">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-cream"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.88-2.88 2.89 2.89 0 0 1 2.88-2.88c.28 0 .56.04.81.13v-3.5a6.37 6.37 0 0 0-.81-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.52a8.27 8.27 0 0 0 4.76 1.5v-3.4a4.85 4.85 0 0 1-1-.07z"/></svg>
      </a>
    </div>
  </div>
</header>

<!-- Nav scripts -->
<script>
  const toggle = document.getElementById('menu-toggle');
  const closeBtn = document.getElementById('menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuLine1 = document.getElementById('menu-line-1');
  const menuLine2 = document.getElementById('menu-line-2');
  const menuLine3 = document.getElementById('menu-line-3');
  let menuOpen = false;

  function closeMenu() {
    menuOpen = false;
    mobileMenu?.classList.add('hidden');
    document.body.style.overflow = '';
    menuLine1?.style.setProperty('transform', 'none');
    menuLine2?.style.setProperty('opacity', '1');
    menuLine3?.style.setProperty('transform', 'none');
  }

  function openMenu() {
    menuOpen = true;
    mobileMenu?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    menuLine1?.style.setProperty('transform', 'rotate(45deg) translate(4px, 4px)');
    menuLine2?.style.setProperty('opacity', '0');
    menuLine3?.style.setProperty('transform', 'rotate(-45deg) translate(4px, -4px)');
  }

  // Hamburger toggle
  toggle?.addEventListener('click', () => {
    menuOpen ? closeMenu() : openMenu();
  });

  // Close button
  closeBtn?.addEventListener('click', closeMenu);

  // Close on link click
  document.querySelectorAll('[data-mobile-link]').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Mobile portfolio dropdown
  const mobilePortfolioToggle = document.getElementById('mobile-portfolio-toggle');
  const mobilePortfolioSubmenu = document.getElementById('mobile-portfolio-submenu');
  const mobilePortfolioChevron = document.getElementById('mobile-portfolio-chevron');

  mobilePortfolioToggle?.addEventListener('click', () => {
    const isOpen = !mobilePortfolioSubmenu?.classList.contains('hidden');
    if (isOpen) {
      mobilePortfolioSubmenu?.classList.add('hidden');
      mobilePortfolioSubmenu?.classList.remove('flex');
      mobilePortfolioChevron?.style.setProperty('transform', 'rotate(0deg)');
    } else {
      mobilePortfolioSubmenu?.classList.remove('hidden');
      mobilePortfolioSubmenu?.classList.add('flex');
      mobilePortfolioChevron?.style.setProperty('transform', 'rotate(180deg)');
    }
  });
</script>

<style>
  .nav-logo img {
    transition: opacity 0.3s ease;
  }
  .nav-logo:hover img {
    opacity: 0.8;
  }
</style>
