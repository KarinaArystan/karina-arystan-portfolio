<footer id="contact" class="bg-charcoal text-cream">
  <!-- "Let's Work Together" Section -->
  <div class="mx-auto max-w-7xl px-8 pt-24 pb-16 md:px-6 lg:px-12">
    <div class="flex flex-col gap-12">
      <div>
        <p class="mb-4 text-[13px] font-medium uppercase tracking-[2px] text-warm-gray-light">
          Get in touch
        </p>
        <h2 class="font-heading text-4xl leading-tight text-terra md:text-7xl lg:text-[88px] lg:leading-[92px]">
          Let's work<br />together.
        </h2>
      </div>

      <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
        <!-- Email -->
        <a
          href="mailto:karina.arystan@gmail.com"
          class="group inline-flex items-center gap-2 text-xl font-medium text-cream transition-colors hover:text-terracotta md:text-2xl"
        >
          karina.arystan@gmail.com
          <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>

        <!-- Social Links -->
        <div class="flex gap-6">
          <a
            href="https://www.instagram.com/customgraphicnovels/"
            class="inline-flex items-center gap-1.5 text-[13px] font-medium uppercase tracking-[1.5px] text-warm-gray-light transition-colors hover:text-terracotta"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            Instagram
          </a>
          <a
            href="https://www.linkedin.com/in/karina-arystan/"
            class="inline-flex items-center gap-1.5 text-[13px] font-medium uppercase tracking-[1.5px] text-warm-gray-light transition-colors hover:text-terracotta"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            LinkedIn
          </a>
          <a
            href="https://www.tiktok.com/@customgraphicnovels.com"
            class="inline-flex items-center gap-1.5 text-[13px] font-medium uppercase tracking-[1.5px] text-warm-gray-light transition-colors hover:text-terracotta"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.88-2.88 2.89 2.89 0 0 1 2.88-2.88c.28 0 .56.04.81.13v-3.5a6.37 6.37 0 0 0-.81-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.52a8.27 8.27 0 0 0 4.76 1.5v-3.4a4.85 4.85 0 0 1-1-.07z"/></svg>
            TikTok
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="mx-auto max-w-7xl border-t border-white/10 px-6 lg:px-12">
    <div class="flex flex-col items-center justify-between gap-4 py-6 md:flex-row">
      <p class="text-xs text-warm-gray-light">
        &copy; 2026 Karina Arystan. All rights reserved.
      </p>
      <p class="text-xs text-warm-gray-light">
        Charlotte, NC
      </p>
    </div>
  </div>
</footer>
