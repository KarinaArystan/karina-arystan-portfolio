---

<BaseLayout title="Content Creation — Karina Arystan">
  <article class="relative bg-charcoal pt-28 pb-24 lg:pt-36 overflow-hidden">
    <!-- Floating circles (behind content) -->
    <div class="absolute inset-0 z-0 pointer-events-none" id="content-floating-circles"></div>

    <!-- Back link -->
    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">
      <a href="/" class="inline-flex items-center gap-2 text-sm text-cream/60 transition-colors hover:text-terracotta">
        &larr; Back to home
      </a>
    </div>

    <!-- Header -->
    <div class="relative z-10 mx-auto max-w-7xl px-6 pt-8 lg:px-12">
      <div class="reveal text-center">
        <h1 class="font-heading text-4xl text-cream md:text-5xl">Content Creation</h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-cream/60">
          Short-form video content — scripted, directed, performed, and edited by me.
          From educational series to brand storytelling across TikTok, Instagram Reels, and YouTube Shorts.
        </p>
      </div>
    </div>

    <!-- Featured video (centered) -->
    <div class="relative z-10 mx-auto max-w-7xl px-6 pt-12 lg:px-12">
      <div class="flex justify-center">
        <div id="featured-wrapper" class="w-full max-w-[360px] transition-all duration-300">
          <div id="featured-frame" class="relative aspect-[9/16] overflow-hidden rounded-2xl bg-black/30 shadow-xl">
            <video
              id="featured-video"
              class="h-full w-full object-cover"
              controls
              autoplay
              playsinline
              preload="auto"
            >
              <source id="featured-source-mp4" src="" type="video/mp4" />
              <source id="featured-source-webm" src="" type="video/webm" />
            </video>
          </div>
        </div>
      </div>
    </div>

    <!-- Video info (below video, centered) -->
    <div class="relative z-10 mx-auto max-w-2xl px-6 pt-8 text-center">
      <span id="featured-brand" class="inline-block rounded-full bg-white/10 px-3 py-1 text-xs font-medium uppercase tracking-wider text-cream/70"></span>
      <h2 id="featured-title" class="mt-3 font-subheading text-2xl uppercase text-cream md:text-3xl"></h2>
      <p id="featured-description" class="mt-3 text-base leading-relaxed text-cream/60"></p>
      <div class="mt-5 flex flex-wrap justify-center gap-2">
        {['Scriptwriter', 'On-Camera', 'Director', 'Editor'].map((role) => (
          <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-cream/70">{role}</span>
        ))}
      </div>
    </div>

    <!-- Thumbnail gallery row -->
    <div class="relative z-10 mx-auto max-w-7xl px-6 pt-14 lg:px-12">
      <p class="mb-4 text-xs font-medium uppercase tracking-wider text-cream/40">All Videos</p>
      <div class="relative">
        <!-- Left arrow -->
        <button
          id="thumb-arrow-left"
          type="button"
          class="absolute -left-1 top-1/2 z-10 hidden -translate-y-1/2 items-center justify-center rounded-full bg-black/50 p-2 text-cream/80 backdrop-blur-sm transition-colors hover:bg-black/70 hover:text-cream lg:flex"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <!-- Right arrow -->
        <button
          id="thumb-arrow-right"
          type="button"
          class="absolute -right-1 top-1/2 z-10 hidden -translate-y-1/2 items-center justify-center rounded-full bg-black/50 p-2 text-cream/80 backdrop-blur-sm transition-colors hover:bg-black/70 hover:text-cream lg:flex"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>

        <div class="flex gap-3 overflow-x-auto pb-4" id="thumbnail-row">
          {videos.map((vid) => (
            <button
              class="content-thumb group relative flex-shrink-0 overflow-hidden rounded-lg bg-black/30 transition-all"
              data-slug={vid.slug}
              data-title={vid.title}
              data-brand={vid.brand}
              data-description={vid.description}
              data-video={vid.video}
              data-webm={vid.webm || ''}
              data-aspect={vid.aspect || '9/16'}
              type="button"
            >
              <div class={`relative overflow-hidden ${vid.aspect === '1/1' ? 'h-[140px] w-[140px]' : 'h-[180px] w-[101px]'}`}>
                <video
                  class="h-full w-full object-cover lazy-video"
                  muted
                  loop
                  playsinline
                  preload="none"
                >
                  {vid.webm && <source data-src={vid.webm} type="video/webm" />}
                  <source data-src={vid.video} type="video/mp4" />
                </video>
                <div class="absolute inset-0 rounded-lg ring-2 ring-transparent transition-all group-[.active]:ring-terracotta"></div>
                <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 to-transparent p-2 pt-6">
                  <p class="text-[9px] font-medium leading-tight text-white/90">{vid.title}</p>
                  <p class="mt-0.5 text-[8px] text-white/50">{vid.brand}</p>
                </div>
              </div>
            </button>
          ))}
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  const featuredVideo = document.getElementById('featured-video') as HTMLVideoElement;
  const sourceWebm = document.getElementById('featured-source-webm') as HTMLSourceElement;
  const sourceMp4 = document.getElementById('featured-source-mp4') as HTMLSourceElement;
  const featuredWrapper = document.getElementById('featured-wrapper')!;
  const featuredFrame = document.getElementById('featured-frame')!;
  const titleEl = document.getElementById('featured-title')!;
  const descEl = document.getElementById('featured-description')!;
  const brandEl = document.getElementById('featured-brand')!;
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.content-thumb');
  const thumbRow = document.getElementById('thumbnail-row')!;

  function setFeaturedVideo(slug: string) {
    const thumb = document.querySelector<HTMLButtonElement>(`.content-thumb[data-slug="${slug}"]`);
    if (!thumb) return;

    const video = thumb.dataset.video || '';
    const webm = thumb.dataset.webm || '';
    const title = thumb.dataset.title || '';
    const description = thumb.dataset.description || '';
    const brand = thumb.dataset.brand || '';
    const aspect = thumb.dataset.aspect || '9/16';

    // Update aspect ratio for featured frame
    const isSquare = aspect === '1/1';
    featuredFrame.style.aspectRatio = isSquare ? '1/1' : '9/16';
    featuredWrapper.style.maxWidth = isSquare ? '480px' : '360px';

    // Update sources (MP4 first — has audio, WebM fallback is silent)
    sourceMp4.src = video;
    sourceWebm.src = webm;
    featuredVideo.muted = false;
    featuredVideo.volume = 1;
    featuredVideo.load();
    featuredVideo.play().catch(() => {
      // Browser blocked unmuted autoplay — start muted, user can unmute via controls
      featuredVideo.muted = true;
      featuredVideo.play().catch(() => {});
    });

    // Update info
    titleEl.textContent = title;
    descEl.textContent = description;
    brandEl.textContent = brand;

    // Update active state
    thumbs.forEach((t) => t.classList.remove('active'));
    thumb.classList.add('active');

    // Scroll thumbnail into view
    thumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });

    // Update hash without scroll jump
    history.replaceState(null, '', `#${slug}`);
  }

  // Thumbnail click handlers
  thumbs.forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const slug = thumb.dataset.slug || '';
      setFeaturedVideo(slug);
      // Scroll to top of featured video
      document.querySelector('article')?.scrollIntoView({ behavior: 'smooth' });
    });
  });

  // Autoplay thumbnails on hover
  thumbs.forEach((thumb) => {
    const vid = thumb.querySelector('video');
    if (!vid) return;
    thumb.addEventListener('mouseenter', () => vid.play().catch(() => {}));
    thumb.addEventListener('mouseleave', () => { vid.pause(); vid.currentTime = 0; });
  });

  // Arrow scroll buttons
  const arrowLeft = document.getElementById('thumb-arrow-left')!;
  const arrowRight = document.getElementById('thumb-arrow-right')!;
  const scrollAmount = 320;

  function updateArrows() {
    const { scrollLeft, scrollWidth, clientWidth } = thumbRow;
    arrowLeft.style.display = scrollLeft > 0 ? 'flex' : 'none';
    arrowRight.style.display = scrollLeft + clientWidth < scrollWidth - 2 ? 'flex' : 'none';
  }

  arrowLeft.addEventListener('click', () => {
    thumbRow.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
  });
  arrowRight.addEventListener('click', () => {
    thumbRow.scrollBy({ left: scrollAmount, behavior: 'smooth' });
  });

  thumbRow.addEventListener('scroll', updateArrows);
  window.addEventListener('resize', updateArrows);

  // Initial load: use hash or default to first video
  const initialSlug = window.location.hash.slice(1) || thumbs[0]?.dataset.slug || '';
  setFeaturedVideo(initialSlug);

  // Init arrows after layout settles
  requestAnimationFrame(updateArrows);

  // --- Lazy-load videos: only load src when visible ---
  const lazyVideos = document.querySelectorAll('video.lazy-video');
  const videoObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const video = entry.target as HTMLVideoElement;
        video.querySelectorAll('source[data-src]').forEach((source) => {
          source.setAttribute('src', source.getAttribute('data-src')!);
          source.removeAttribute('data-src');
        });
        video.load();
        video.play().catch(() => {});
        videoObserver.unobserve(video);
      }
    });
  }, { rootMargin: '200px' });
  lazyVideos.forEach((v) => videoObserver.observe(v));
</script>

<script>
  // --- Floating circles for content page ---
  const circlesContainer = document.getElementById('content-floating-circles');
  if (circlesContainer) {
    const colors = [
      'rgba(174, 81, 70, 0.15)',    // terra
      'rgba(231, 189, 170, 0.12)',  // terra-mid
      'rgba(80, 84, 56, 0.15)',     // sage-deep
      'rgba(177, 192, 161, 0.12)',  // sage-mid
      'rgba(234, 216, 214, 0.12)',  // terra-light
      'rgba(210, 211, 196, 0.1)',   // sage-light
      'rgba(237, 218, 196, 0.1)',   // terra-sand
      'rgba(123, 140, 110, 0.12)',  // olive
    ];

    interface Circle {
      el: HTMLDivElement;
      x: number;
      y: number;
      vx: number;
      vy: number;
      size: number;
      wobbleSpeed: number;
      wobbleAmp: number;
      phase: number;
    }

    const circles: Circle[] = [];
    const isMobile = window.innerWidth < 768;
    const count = isMobile ? 10 : 18;
    let time = 0;

    for (let i = 0; i < count; i++) {
      const el = document.createElement('div');
      const size = 20 + Math.random() * 200;
      const color = colors[Math.floor(Math.random() * colors.length)];

      el.style.cssText = `
        position: absolute;
        width: ${size}px;
        height: ${size}px;
        border-radius: 50%;
        background: ${color};
        filter: blur(${1 + Math.random() * 4}px);
        will-change: transform;
      `;

      circlesContainer.appendChild(el);

      const speedFactor = 1.2 - (size / 250);
      const baseSpeed = (0.03 + Math.random() * 0.07) * speedFactor;
      const angle = Math.random() * Math.PI * 2;

      circles.push({
        el,
        x: Math.random() * 100,
        y: Math.random() * 100,
        vx: Math.cos(angle) * baseSpeed,
        vy: Math.sin(angle) * baseSpeed,
        size,
        wobbleSpeed: 0.005 + Math.random() * 0.015,
        wobbleAmp: 0.02 + Math.random() * 0.04,
        phase: Math.random() * Math.PI * 2,
      });
    }

    let circlesRunning = true;

    function animateCircles() {
      if (!circlesRunning) return;
      time++;
      for (const c of circles) {
        const wobbleX = Math.sin(time * c.wobbleSpeed + c.phase) * c.wobbleAmp;
        const wobbleY = Math.cos(time * c.wobbleSpeed * 0.7 + c.phase + 1.5) * c.wobbleAmp;

        c.x += c.vx + wobbleX;
        c.y += c.vy + wobbleY;

        if (c.x < -8) { c.vx = Math.abs(c.vx); }
        else if (c.x > 108) { c.vx = -Math.abs(c.vx); }
        if (c.y < -8) { c.vy = Math.abs(c.vy); }
        else if (c.y > 108) { c.vy = -Math.abs(c.vy); }

        c.el.style.transform = `translate(${c.x}vw, ${c.y}vh)`;
      }
      requestAnimationFrame(animateCircles);
    }

    animateCircles();

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        circlesRunning = false;
      } else {
        circlesRunning = true;
        animateCircles();
      }
    });
  }
</script>

<style>
  /* Hide scrollbar on thumbnail row */
  #thumbnail-row {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #thumbnail-row::-webkit-scrollbar {
    display: none;
  }
</style>
