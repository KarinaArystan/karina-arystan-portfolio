---
import BaseLayout from '../layouts/BaseLayout.astro';
import Marquee from '../components/Marquee.astro';
---

<BaseLayout title="About — Karina Arystan">
  <section class="px-6 pt-32 pb-24 lg:px-12 lg:pt-40 lg:pb-32">
    <div class="mx-auto max-w-7xl">
      <!-- Header -->
      <div class="grid gap-12 md:grid-cols-5 md:gap-16">
        <!-- Photo (2 cols) -->
        <div class="reveal md:col-span-2">
          <div class="aspect-[3/4] overflow-hidden">
            <img
              src="/images/about-photo.jpg"
              alt="Karina Arystan"
              class="h-full w-full object-cover"
            />
          </div>
        </div>

        <!-- Bio (2 cols) -->
        <div class="reveal md:col-span-3">
          <p class="mb-4 text-sm font-medium uppercase tracking-widest text-terracotta">About</p>
          <h1 class="font-heading text-4xl leading-tight text-olive md:text-5xl">
            Creative storyteller, brand builder, on-camera presence.
          </h1>
          <div class="mt-8 space-y-5 text-lg leading-relaxed text-warm-gray">
            <p>
              I'm Karina — a content creator and brand developer with 10+ years of experience
              in creative production. My journey has taken me from Kazakhstan to Malaysia to China
              to the US, and that global perspective shapes everything I create.
            </p>
            <p>
              I specialize in the space where brands meet content — building visual identities
              that tell a story, then bringing those stories to life through short-form video.
              I write the scripts, step in front of the camera, and edit the final cut.
              I also design the logos, packaging, and websites that make brands feel complete.
            </p>
            <p>
              When I'm not creating, I'm exploring how AI tools can enhance creative workflows
              — from AI-assisted web development to AI-powered image generation and video enhancement.
            </p>
          </div>

          <!-- Resume download -->
          <div class="mt-10">
            <a
              href="/Karina_Arystan_Resume.pdf"
              class="inline-flex items-center gap-3 rounded-full bg-charcoal px-7 py-3.5 text-sm font-semibold text-cream transition-all hover:bg-terracotta"
              download
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
              </svg>
              Download Resume
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section class="bg-cream-dark px-6 py-24 lg:px-12 lg:py-32">
    <div class="mx-auto max-w-7xl">
      <h2 class="reveal font-heading text-3xl text-olive md:text-4xl">Skills & Tools</h2>

      <div class="mt-12 grid gap-12 md:grid-cols-2" data-reveal-group>
        <!-- Creative -->
        <div data-reveal-item>
          <h3 class="mb-6 text-sm font-medium uppercase tracking-widest text-terracotta">Creative</h3>
          <div class="flex flex-wrap gap-2">
            {[
              'Short-Form Video Production',
              'Script Writing',
              'On-Camera Talent',
              'Creative Direction',
              'Video Editing & Post-Production',
              'Photo Editing',
              'Custom Illustration',
              'Brand Storytelling',
              'Content Strategy',
              'SEO Content Writing',
              'Production Management',
            ].map((skill) => (
              <span class="rounded-full border border-charcoal/15 bg-cream px-4 py-2 text-sm font-medium text-charcoal">
                {skill}
              </span>
            ))}
          </div>
        </div>

        <!-- Technical -->
        <div data-reveal-item>
          <h3 class="mb-6 text-sm font-medium uppercase tracking-widest text-terracotta">Technical</h3>
          <div class="flex flex-wrap gap-2">
            {[
              'Adobe Premiere Pro',
              'Final Cut Pro',
              'After Effects',
              'Photoshop',
              'Lightroom',
              'Illustrator',
              'InDesign',
              'Figma',
              'Canva',
              'CapCut Pro',
              'Runway AI',
              'Midjourney',
              'Claude Code',
              'Astro',
              'Supabase',
              'Google Analytics',
              'Meta Business Suite',
              'Later',
            ].map((tool) => (
              <span class="rounded-full border border-charcoal/15 bg-cream px-4 py-2 text-sm font-medium text-charcoal">
                {tool}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section class="px-6 py-24 lg:px-12 lg:py-32">
    <div class="mx-auto max-w-7xl">
      <h2 class="reveal font-heading text-3xl text-olive md:text-4xl">Experience</h2>

      <div class="reveal mt-12 space-y-12">
        {[
          {
            title: 'Content Creator & Creative Director',
            company: 'Custom Graphic Novels',
            period: '2024 — Present',
            location: 'Remote',
            highlights: [
              'End-to-end social media content strategy across Instagram, TikTok, and YouTube Shorts',
              'Script writing, on-camera talent, video editing, color grading, sound design',
              'Brand voice, content guidelines, and visual identity system from scratch',
              'Built complete brand website using AI-assisted development',
            ],
          },
          {
            title: 'Director of Production',
            company: 'Skira Creative LLC',
            period: 'May 2023 — Mar 2025',
            location: 'Los Angeles, CA',
            highlights: [
              'Directed video and photo production for luxury real estate clients',
              'Managed on-set crews and led a team of 3 across concurrent projects',
              'Led web design process in Figma with in-house development team',
            ],
          },
          {
            title: 'Brand Developer & Content Creator',
            company: 'De La Creme',
            period: 'Feb 2022 — Dec 2023',
            location: 'Los Angeles, CA',
            highlights: [
              'Filmed and edited brand video content for social media and web',
              'Designed email campaigns, landing pages, and digital editorial content',
              'Maintained consistent visual identity across all channels',
            ],
          },
        ].map((role) => (
          <div class="border-b border-cream-dark pb-12 last:border-0">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <h3 class="font-subheading text-xl uppercase md:text-2xl">{role.title}</h3>
                <p class="mt-1 font-medium text-terracotta">{role.company}</p>
              </div>
              <div class="text-right text-sm text-warm-gray">
                <p>{role.period}</p>
                <p>{role.location}</p>
              </div>
            </div>
            <ul class="mt-4 space-y-2">
              {role.highlights.map((h) => (
                <li class="flex items-start gap-3 text-warm-gray">
                  <span class="mt-2 h-1 w-1 flex-shrink-0 rounded-full bg-terracotta"></span>
                  {h}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Education & Languages -->
  <section class="bg-olive px-6 py-24 text-cream lg:px-12 lg:py-32">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-16 md:grid-cols-2">
        <!-- Education -->
        <div class="reveal">
          <h2 class="font-heading text-3xl text-charcoal md:text-4xl">Education</h2>
          <div class="mt-8 space-y-6">
            <div>
              <p class="font-subheading text-lg uppercase">Bachelor's Degree</p>
              <p class="mt-1 text-warm-gray-light">Santa Monica College · 2016</p>
            </div>
            <div>
              <p class="font-subheading text-lg uppercase">Associate's Degree</p>
              <p class="mt-1 text-warm-gray-light">Limkokwing University · 2014</p>
            </div>
            <div>
              <p class="font-subheading text-lg uppercase">Certification in Translation</p>
              <p class="mt-1 text-warm-gray-light">Beijing Language and Culture University · 2011</p>
            </div>
          </div>
        </div>

        <!-- Languages -->
        <div class="reveal">
          <h2 class="font-heading text-3xl text-charcoal md:text-4xl">Languages</h2>
          <div class="mt-8 space-y-4">
            {[
              { lang: 'English', level: 'Native / Bilingual' },
              { lang: 'Russian', level: 'Native / Bilingual' },
              { lang: 'Mandarin Chinese', level: 'Professional' },
            ].map((l) => (
              <div class="flex items-center justify-between border-b border-white/10 pb-4">
                <span class="font-subheading text-xl uppercase">{l.lang}</span>
                <span class="text-sm text-warm-gray-light">{l.level}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Marquee -->
  <div class="py-8">
    <Marquee
      text="Content Creator · Brand Developer · Creative Director · Video Editor · Scriptwriter · On-Camera Talent · Web Designer"
      speed="slow"
      class="font-heading text-lg uppercase tracking-widest text-charcoal/10 md:text-2xl"
    />
  </div>
</BaseLayout>
