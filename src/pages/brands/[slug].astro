---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CatalogueViewer from '../../components/CatalogueViewer.astro';

const cdn = 'https://pub-3533267dbae54c5d81969005ee934878.r2.dev';

export function getStaticPaths() {
  return [
    { params: { slug: 'otks' } },
    { params: { slug: 'dlc' } },
    { params: { slug: 'cgn' } },
    { params: { slug: 'big-chief' } },
  ];
}

// Brand project data (will migrate to Content Collections later)
const projects: Record<string, any> = {
  otks: {
    name: 'The OTKs',
    description: 'Brand Identity & Content Creation',
    year: '2023',
    roles: ['Brand Developer', 'Creative Director'],
    context: 'Freelance · Remote',
    deliverables: ['Brand Identity', 'Logo Design', 'Typography System', 'Color Palette', 'Social Media Templates', 'Photography Direction'],
    hero: '/images/brands/the-otks/otk-photoshoot-01.jpg',
    brief: '',
    approach: '',
    result: '',
    images: [],
    next: { slug: 'dlc', name: 'De La Creme' },
  },
  dlc: {
    name: 'De La Creme',
    description: 'Brand Development & Content Creation',
    year: '2022 — 2023',
    roles: ['Brand Developer', 'Content Creator'],
    context: 'In-house · Los Angeles, CA',
    deliverables: ['Brand Identity', 'Packaging Design', 'Custom Illustration', 'Apparel Design', 'Print Collateral', 'Photography Direction', 'Social Content'],
    hero: '/images/brands/dlc/hero.png',
    brief: '',
    approach: '',
    result: '',
    images: [],
    next: { slug: 'cgn', name: 'Custom Graphic Novels' },
  },
  cgn: {
    name: 'Custom Graphic Novels',
    description: 'Brand Identity & Web Design',
    year: '2024 — Present',
    roles: ['Creative Director', 'Brand Founder'],
    context: 'Solo · Remote',
    deliverables: ['Brand Voice', 'Visual Identity', 'Content Strategy', 'E-Commerce Platform'],
    hero: '/images/brands/cgn/page-cover-photo.jpg',
    brief: '',
    approach: '',
    result: '',
    images: [],
    next: { slug: 'big-chief', name: 'Big Chief' },
  },
  'big-chief': {
    name: 'Big Chief',
    description: 'Brand Identity & Packaging Design',
    year: '2023',
    roles: ['Brand Developer', 'Packaging Designer'],
    context: 'Contract · Los Angeles, CA',
    deliverables: ['Brand Identity', 'Logo Design', 'Packaging Design', 'Print Production', 'Catalogue Design'],
    hero: '/images/brands/big-chief/bag-hero.png',
    brief: '',
    approach: '',
    result: '',
    images: [],
    next: { slug: 'otks', name: 'The OTKs' },
  },
};

const { slug } = Astro.params;
const project = projects[slug as string];
const isCGN = slug === 'cgn';
const isDLC = slug === 'dlc';
const isBigChief = slug === 'big-chief';
const isOTKs = slug === 'otks';

if (!project) {
  return Astro.redirect('/brands');
}
---

<BaseLayout title={`${project.name} — Karina Arystan`}>
  <article class="pt-28 lg:pt-36">
    <!-- Back link -->
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <a href="/brands" class="inline-flex items-center gap-2 text-sm text-warm-gray transition-colors hover:text-terracotta">
        &larr; All projects
      </a>
    </div>

    <!-- Hero image -->
    {project.hero ? (
      <div class="mt-8 px-6 lg:px-12">
        <div class="mx-auto max-w-7xl overflow-hidden">
          <img
            src={project.hero}
            alt={`${project.name} hero`}
            class="max-h-[600px] w-full object-cover object-center"
            loading="eager"
          />
        </div>
      </div>
    ) : project.images.length > 0 ? (
      <div class="mt-8 px-6 lg:px-12">
        <div class="mx-auto max-w-7xl overflow-hidden">
          <img
            src={project.images[0].src}
            alt={project.images[0].alt}
            class="w-full object-cover"
            loading="eager"
          />
        </div>
      </div>
    ) : (
      <div class="mt-8 px-6 lg:px-12">
        <div class="mx-auto max-w-7xl overflow-hidden bg-cream-dark">
          <div class="flex aspect-[21/9] items-center justify-center">
            <span class="font-heading text-4xl text-warm-gray-light/30">{project.name}</span>
          </div>
        </div>
      </div>
    )}

    <!-- Project meta -->
    <div class="mx-auto max-w-7xl px-6 pt-12 lg:px-12">
      <div class="reveal flex flex-wrap items-start justify-between gap-8 border-b border-cream-dark pb-8">
        <div>
          <h1 class="font-heading text-4xl md:text-5xl">{project.name}</h1>
          <p class="mt-2 text-lg text-warm-gray">{project.description}</p>
        </div>
        <div class="flex flex-wrap gap-6 text-sm">
          <div>
            <p class="font-medium uppercase tracking-wider text-warm-gray-light">Year</p>
            <p class="mt-1 text-charcoal">{project.year}</p>
          </div>
          <div>
            <p class="font-medium uppercase tracking-wider text-warm-gray-light">Role</p>
            <p class="mt-1 text-charcoal">{project.roles.join(' · ')}</p>
          </div>
          {project.context && (
            <div>
              <p class="font-medium uppercase tracking-wider text-warm-gray-light">Context</p>
              <p class="mt-1 text-charcoal">{project.context}</p>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Deliverables tags -->
    <div class="mx-auto max-w-7xl px-6 pt-6 lg:px-12">
      <div class="reveal flex flex-wrap gap-2">
        {project.deliverables.map((d: string) => (
          <span class="rounded-full bg-cream-dark px-4 py-1.5 text-sm font-medium text-warm-gray">
            {d}
          </span>
        ))}
      </div>
    </div>

    {/* ═══ GENERIC SECTIONS ═══ */}
    {!isCGN && !isDLC && !isBigChief && !isOTKs && (
      <>
        <!-- The Brief -->
        <div class="mx-auto max-w-7xl px-6 pt-16 lg:px-12">
          <div class="reveal mx-auto max-w-3xl">
            <p class="mb-3 text-sm font-medium uppercase tracking-widest text-terracotta">The Brief</p>
            <p class="font-heading text-xl leading-relaxed md:text-2xl">{project.brief}</p>
          </div>
        </div>

        <!-- Visual showcase (if images exist) -->
        {project.images.length > 1 && (
          <div class="mx-auto max-w-7xl px-6 pt-16 lg:px-12">
            <div class="grid gap-4 md:grid-cols-2" data-reveal-group>
              {project.images.slice(1, 3).map((img: any) => (
                <div class="overflow-hidden" data-reveal-item>
                  <img src={img.src} alt={img.alt} class="w-full object-cover" loading="lazy" />
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- The Approach -->
        <div class="mx-auto max-w-7xl px-6 pt-16 lg:px-12">
          <div class="reveal mx-auto max-w-3xl">
            <p class="mb-3 text-sm font-medium uppercase tracking-widest text-terracotta">The Approach</p>
            <p class="text-lg leading-relaxed text-warm-gray">{project.approach}</p>
          </div>
        </div>

        <!-- Additional images -->
        {project.images.length > 3 && (
          <div class="mx-auto max-w-7xl px-6 pt-16 lg:px-12">
            <div class="reveal overflow-hidden">
              <img
                src={project.images[3].src}
                alt={project.images[3].alt}
                class="w-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
        )}

        <!-- The Result -->
        <div class="mx-auto max-w-7xl px-6 pt-16 pb-24 lg:px-12">
          <div class="reveal mx-auto max-w-3xl">
            <p class="mb-3 text-sm font-medium uppercase tracking-widest text-terracotta">The Result</p>
            <p class="text-lg leading-relaxed text-warm-gray">{project.result}</p>
          </div>
        </div>
      </>
    )}

    {/* ═══ OTKS-SPECIFIC: About This Project ═══ */}
    {isOTKs && (
      <div class="mx-auto max-w-7xl px-6 pt-16 lg:px-12">
        <div class="reveal text-center">
          <p class="mb-8 text-sm font-medium uppercase tracking-widest text-terracotta">— About This Project —</p>
        </div>
        <div class="reveal mx-auto max-w-3xl rounded-2xl border border-cream-dark bg-cream-dark/30 p-8 md:p-12">
          <p class="text-lg leading-relaxed text-warm-gray">
            The OTKs is a premium over-the-knee sock brand targeting style-conscious millennials who value quality craftsmanship and refined aesthetics. I developed the complete brand identity from concept — building a visual system rooted in chic sophistication with vintage-inspired sensibility.
          </p>
          <p class="mt-6 text-lg leading-relaxed text-warm-gray">
            The identity centers on an interwoven monogram mark that feels both contemporary and timeless, paired with a muted color palette of dusty rose, taupe, charcoal, burgundy, and forest green. The type system pairs Bauer Bodoni Condensed for editorial display with TT Chocolates for modern body text and Eleganto Sans for the logo wordmark — balancing elegance with approachability across every touchpoint from social media to product tags.
          </p>
        </div>
      </div>
    )}

    {/* ═══ OTKS-SPECIFIC: Brand Identity System ═══ */}
    {isOTKs && (
      <div class="mx-auto max-w-7xl px-6 pt-20 lg:px-12">
        <div class="reveal">
          <p class="mb-12 text-sm font-medium uppercase tracking-widest text-terracotta">Brand Identity System</p>
        </div>

        <div class="mb-16 grid gap-12 md:grid-cols-2">
          {/* ── Color Palette ── */}
          <div>
            <div class="reveal">
              <h3 class="mb-6 font-heading text-2xl text-charcoal">Color Palette</h3>
            </div>
            <div class="reveal flex flex-wrap gap-6">
              {[
                { name: 'Dusty Pink', hex: '#dfbdbd' },
                { name: 'Taupe', hex: '#cfbab1' },
                { name: 'Silver', hex: '#e6e6e6', border: true },
                { name: 'Burgundy', hex: '#a52b31' },
                { name: 'Blush', hex: '#e7dfda', border: true },
                { name: 'Charcoal', hex: '#544f50' },
                { name: 'Cream', hex: '#f4eee0', border: true },
                { name: 'Forest', hex: '#335741' },
              ].map((c) => (
                <div class="flex flex-col items-center gap-2">
                  <div class="h-16 w-16 rounded-lg shadow-sm" style={`background-color: ${c.hex};${c.border ? ' border: 1px solid #e5d89d;' : ''}`}></div>
                  <span class="text-xs font-medium text-warm-gray">{c.name}</span>
                  <span class="text-[10px] text-warm-gray-light">{c.hex}</span>
                </div>
              ))}
            </div>
          </div>

          {/* ── Typography ── */}
          <div>
            <div class="reveal">
              <h3 class="mb-6 font-heading text-2xl text-charcoal">Typography</h3>
            </div>
            <div class="reveal flex flex-col gap-5">
              <div class="border-b border-cream-dark pb-4">
                <p class="mb-1 text-xs font-medium uppercase tracking-wider text-warm-gray-light">Primary Display</p>
                <p class="otks-bodoni text-3xl text-charcoal md:text-4xl">Bauer Bodoni Condensed</p>
              </div>
              <div class="border-b border-cream-dark pb-4">
                <p class="mb-1 text-xs font-medium uppercase tracking-wider text-warm-gray-light">Body</p>
                <p class="otks-chocolates text-2xl text-charcoal md:text-3xl">TT Chocolates</p>
              </div>
              <div>
                <p class="mb-1 text-xs font-medium uppercase tracking-wider text-warm-gray-light">Logo Font</p>
                <p class="otks-eleganto text-2xl tracking-wider text-charcoal md:text-3xl">Eleganto Sans</p>
              </div>
            </div>
          </div>
        </div>

        {/* ── Mood Board ── */}
        <div class="mb-16">
          <div class="reveal">
            <h3 class="mb-8 font-heading text-2xl text-charcoal">Mood Board</h3>
          </div>
          <div class="reveal overflow-hidden rounded-2xl">
            <img src="/images/brands/the-otks/otks-mood-board.png" alt="The OTKs — Mood board: vintage-inspired fashion photography, chic sophistication" class="w-full object-cover" loading="lazy" />
          </div>
        </div>

        {/* ── Logo System ── */}
        <div class="mb-16">
          <div class="reveal">
            <h3 class="mb-8 font-heading text-2xl text-charcoal">Logo System</h3>
          </div>

          {/* 2-col: monogram on taupe + monogram on white */}
          <div class="grid gap-4 md:grid-cols-2" data-reveal-group>
            <div class="flex items-center justify-center overflow-hidden rounded-2xl p-10" style="background-color: #b8a69e;" data-reveal-item>
              <img src="/images/brands/the-otks/logo-01.png" alt="The OTKs — Monogram on taupe" class="max-h-[280px] object-contain" loading="lazy" />
            </div>
            <div class="flex items-center justify-center overflow-hidden rounded-2xl bg-white p-10" style="border: 1px solid #e6e6e6;" data-reveal-item>
              <img src="/images/brands/the-otks/logo-02.png" alt="The OTKs — Monogram on white" class="max-h-[280px] object-contain" loading="lazy" />
            </div>
          </div>

          {/* O lettermark on sage */}
          <div class="reveal mt-4 flex items-center justify-center overflow-hidden rounded-2xl p-10" style="background-color: #b5c4b1;">
            <img src="/images/brands/the-otks/logo-03.png" alt="The OTKs — O Lettermark on sage" class="max-h-[240px] object-contain" loading="lazy" />
          </div>

          {/* 2-col: full logo dark + full logo light */}
          <div class="mt-4 grid gap-4 md:grid-cols-2" data-reveal-group>
            <div class="flex items-center justify-center overflow-hidden rounded-2xl bg-charcoal p-10" data-reveal-item>
              <img src="/images/brands/the-otks/logo-04.png" alt="The OTKs — Full logo on dark" class="max-h-[180px] object-contain" loading="lazy" />
            </div>
            <div class="flex items-center justify-center overflow-hidden rounded-2xl bg-white p-10" style="border: 1px solid #e6e6e6;" data-reveal-item>
              <img src="/images/brands/the-otks/logo-05.png" alt="The OTKs — Full logo on white" class="max-h-[180px] object-contain" loading="lazy" />
            </div>
          </div>

          {/* Logo mark explanation */}
          <div class="reveal mt-4 overflow-hidden rounded-2xl">
            <img src="/images/brands/the-otks/otks-logo-mark.jpg" alt="The OTKs — Logo mark: interwoven monogram explanation" class="w-full object-cover" loading="lazy" />
          </div>

          {/* Primary logo usage */}
          <div class="reveal mt-4 overflow-hidden rounded-2xl">
            <img src="/images/brands/the-otks/otks-logo-use.png" alt="The OTKs — Primary logo: four colorway applications" class="w-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    )}

    {/* ═══ OTKS-SPECIFIC: Social Media & Content ═══ */}
    {isOTKs && (
      <div class="mx-auto max-w-7xl px-6 pt-20 lg:px-12">
        <div class="reveal">
          <p class="mb-2 text-sm font-medium uppercase tracking-widest text-terracotta">Social Media & Content</p>
          <p class="mb-3 max-w-3xl text-base leading-relaxed text-warm-gray">
            Designed a complete social media template system for Instagram — including story templates, post layouts, and a cohesive grid strategy that balances product photography with branded graphic content.
          </p>
          <div class="mb-8 flex flex-wrap gap-2">
            {['Social Templates', 'Instagram Grid', 'Content Strategy', 'Photography Direction'].map((s) => (
              <span class="rounded-full bg-cream-dark px-3 py-1 text-xs font-medium text-warm-gray">{s}</span>
            ))}
          </div>
        </div>

        <div class="reveal overflow-hidden rounded-2xl">
          <img src="/images/brands/the-otks/otk-social-use.jpg" alt="The OTKs — Social media templates: story, post, and grid layouts" class="w-full object-cover" loading="lazy" />
        </div>

        {/* IG grid video */}
        <div class="reveal mt-4 overflow-hidden rounded-2xl">
          <video class="w-full object-cover" autoplay loop muted playsinline>
            <source src="/images/brands/the-otks/ig-grid-layout-design.mp4" type="video/mp4" />
          </video>
          <p class="mt-3 text-xs text-warm-gray-light">Instagram grid layout — animated walkthrough</p>
        </div>
      </div>
    )}

    {/* ═══ OTKS-SPECIFIC: Photography ═══ */}
    {isOTKs && (
      <div class="mx-auto max-w-7xl px-6 pt-20 pb-24 lg:px-12">
        <div class="reveal">
          <p class="mb-2 text-sm font-medium uppercase tracking-widest text-terracotta">Photography Direction</p>
          <p class="mb-8 max-w-3xl text-base leading-relaxed text-warm-gray">
            Art directed product photography emphasizing texture, natural light, and refined styling — showcasing the socks in aspirational, editorial-quality compositions.
          </p>
        </div>
        <div class="grid gap-4 md:grid-cols-2" data-reveal-group>
          <div class="overflow-hidden rounded-2xl" data-reveal-item>
            <img src="/images/brands/the-otks/otk-photoshoot-01.jpg" alt="The OTKs — Product photography: window light, styled composition" class="h-full w-full object-cover" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-2xl" data-reveal-item>
            <img src="/images/brands/the-otks/otk-photoshoot-02.jpg" alt="The OTKs — Product photography: detail shot, natural light" class="h-full w-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    )}

    {/* ═══ CGN-SPECIFIC: About This Project ═══ */}
    {isCGN && (
      <div class="mx-auto max-w-7xl px-6 pt-16 lg:px-12">
        <div class="reveal text-center">
          <p class="mb-8 text-sm font-medium uppercase tracking-widest text-terracotta">— About This Project —</p>
        </div>
        <div class="reveal mx-auto max-w-3xl rounded-2xl border border-cream-dark bg-cream-dark/30 p-8 md:p-12">
          <p class="text-lg leading-relaxed text-warm-gray">
            Custom Graphic Novels transforms real love stories into museum-quality, hand-bound illustrated graphic novels. Before this project, this product category did not exist. I founded the brand, developed its identity, wrote its voice, and built the platform to deliver it — starting from a single idea and zero assets.
          </p>
          <p class="mt-6 text-lg leading-relaxed text-warm-gray">
            The brand needed to communicate two things simultaneously: the emotional weight of the product (this is a heirloom, not a novelty) and the clarity of the process (ordering a fully custom illustrated book needed to feel accessible, not overwhelming). Every brand decision — the typography, the color palette, the tagline — was made to hold both of those truths at once.
          </p>
          <p class="mt-6 text-lg leading-relaxed text-warm-gray">
            The result is a brand that positions itself as the only company in the world doing what it does — because it is. "Love Stories Worth Telling" is not just a tagline. It's the entire brand strategy compressed into four words.
          </p>
        </div>
      </div>
    )}

    {/* ═══ CGN-SPECIFIC: Brand Identity ═══ */}
    {isCGN && (
      <div class="mx-auto max-w-7xl px-6 pt-20 lg:px-12">
        <div class="reveal">
          <p class="mb-2 text-sm font-medium uppercase tracking-widest text-terracotta">Brand Identity</p>
          <p class="mb-12 max-w-3xl text-base leading-relaxed text-warm-gray">
            The visual and verbal foundation built from scratch.
            Full platform build &rarr; <a href="/web/custom-graphic-novels" class="text-terracotta underline decoration-terracotta/30 underline-offset-2 transition-colors hover:text-terra-mid">View Web Project</a>
          </p>
        </div>

        <div class="grid gap-12 lg:grid-cols-2">
          {/* ── Color Palette ── */}
          <div class="reveal">
            <h3 class="mb-6 font-heading text-2xl text-charcoal">Color Palette</h3>
            <div class="flex flex-col gap-6">
              <div>
                <p class="mb-2 text-xs font-medium uppercase tracking-wider text-warm-gray-light">Gold variants</p>
                <div class="flex flex-wrap gap-3">
                  {[
                    { hex: '#6a5f2c' },
                    { hex: '#938432' },
                    { hex: '#231f20' },
                    { hex: '#b9ae7f' },
                    { hex: '#c1b06b' },
                  ].map((c) => (
                    <div class="flex flex-col items-center gap-1.5">
                      <div class="h-14 w-14 rounded-lg shadow-sm" style={`background-color: ${c.hex};`}></div>
                      <span class="text-[10px] font-medium text-warm-gray">{c.hex}</span>
                    </div>
                  ))}
                </div>
              </div>
              <div>
                <p class="mb-2 text-xs font-medium uppercase tracking-wider text-warm-gray-light">Dust Rose variants</p>
                <div class="flex flex-wrap gap-3">
                  {[
                    { hex: '#754037' },
                    { hex: '#975749' },
                  ].map((c) => (
                    <div class="flex flex-col items-center gap-1.5">
                      <div class="h-14 w-14 rounded-lg shadow-sm" style={`background-color: ${c.hex};`}></div>
                      <span class="text-[10px] font-medium text-warm-gray">{c.hex}</span>
                    </div>
                  ))}
                </div>
              </div>
              <div>
                <p class="mb-2 text-xs font-medium uppercase tracking-wider text-warm-gray-light">Creme variants</p>
                <div class="flex flex-wrap gap-3">
                  {[
                    { hex: '#e8deb3' },
                    { hex: '#faf4dc' },
                    { hex: '#ede9cf' },
                    { hex: '#e5d89d' },
                  ].map((c) => (
                    <div class="flex flex-col items-center gap-1.5">
                      <div class="h-14 w-14 rounded-lg border border-cream-dark shadow-sm" style={`background-color: ${c.hex};`}></div>
                      <span class="text-[10px] font-medium text-warm-gray">{c.hex}</span>
                    </div>
                  ))}
                </div>
              </div>
              <div>
                <p class="mb-2 text-xs font-medium uppercase tracking-wider text-warm-gray-light">Sage Blue</p>
                <div class="flex flex-wrap gap-3">
                  <div class="flex flex-col items-center gap-1.5">
                    <div class="h-14 w-14 rounded-lg shadow-sm" style="background-color: #4f6967;"></div>
                    <span class="text-[10px] font-medium text-warm-gray">#4f6967</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          {/* ── Typography ── */}
          <div class="reveal">
            <h3 class="mb-6 font-heading text-2xl text-charcoal">Typography</h3>
            <div class="flex flex-col gap-5">
              <div class="border-b border-cream-dark pb-4">
                <p class="mb-1 text-xs font-medium uppercase tracking-wider text-warm-gray-light">Display</p>
                <p class="cgn-choose-elegant text-3xl text-charcoal md:text-4xl">Love Stories Worth Telling</p>
              </div>
              <div class="border-b border-cream-dark pb-4">
                <p class="mb-1 text-xs font-medium uppercase tracking-wider text-warm-gray-light">Display Alternate</p>
                <p class="cgn-elegant text-2xl text-charcoal md:text-3xl">A Story Only You Can Tell</p>
              </div>
              <div class="border-b border-cream-dark pb-4">
                <p class="mb-1 text-xs font-medium uppercase tracking-wider text-warm-gray-light">Serif Body</p>
                <p class="cgn-braven text-2xl text-charcoal md:text-3xl">Every story deserves to be told.</p>
              </div>
              <div class="border-b border-cream-dark pb-4">
