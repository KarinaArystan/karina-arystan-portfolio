---
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = [
  {
    name: 'The OTKs',
    slug: 'otks',
    description: 'Brand Identity & Content Creation',
    tags: ['Logo', 'Typography', 'Social Media', 'Photography'],
    year: '2023',
    image: '/images/brands/the-otks/the-otks-card-thumbnail.png',
  },
  {
    name: 'De La Creme',
    slug: 'dlc',
    description: 'Brand Development & Content Creation',
    tags: ['Identity', 'Packaging', 'Video', 'Web Design'],
    year: '2022–2023',
    image: '/images/brands/dlc/dlc-card-thumbnail.jpg',
  },
  {
    name: 'Custom Graphic Novels',
    slug: 'cgn',
    description: 'Brand Identity & Web Design',
    tags: ['Identity', 'Website', 'Content Strategy', 'AI-Assisted Dev'],
    year: '2024',
    image: '/images/brands/cgn/cgn-card-thumbnail.png',
  },
  {
    name: 'Big Chief',
    slug: 'big-chief',
    description: 'Brand Identity & Packaging Design',
    tags: ['Logo', 'Packaging', 'Catalogue', 'Print Production'],
    year: '2023',
    image: '/images/brands/big-chief/big-chief-card-thumbnail.png',
  },
];
---

<BaseLayout title="Brand Development — Karina Arystan">
  <section class="px-6 pt-32 pb-24 lg:px-12 lg:pt-40 lg:pb-32">
    <div class="mx-auto max-w-7xl">
      <!-- Header -->
      <div class="reveal mb-16">
        <a href="/" class="mb-8 inline-flex items-center gap-2 text-sm text-warm-gray transition-colors hover:text-terracotta">
          &larr; Back to home
        </a>
        <h1 class="font-heading text-4xl md:text-6xl">Brand Development</h1>
        <p class="mt-4 max-w-2xl text-lg text-warm-gray">
          From visual identity to packaging to web — I build brands that feel cohesive across every touchpoint.
        </p>
      </div>

      <!-- Project grid -->
      <div class="grid gap-8 md:grid-cols-2" data-reveal-group>
        {projects.map((project) => (
          <a
            href={`/brands/${project.slug}`}
            class="group block overflow-hidden bg-cream-dark transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
            data-reveal-item
          >
            <!-- Image area -->
            <div class="relative aspect-[4/3] overflow-hidden bg-warm-gray-light/20">
              {project.image ? (
                <>
                  <img
                    src={project.image}
                    alt={project.name}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-charcoal/40 to-transparent" />
                </>
              ) : (
                <div class="flex h-full items-center justify-center transition-transform duration-500 group-hover:scale-105">
                  <span class="font-heading text-3xl text-warm-gray-light/40">{project.name}</span>
                </div>
              )}
            </div>
            <!-- Info -->
            <div class="p-8">
              <div class="flex items-start justify-between">
                <div>
                  <h2 class="font-heading text-2xl text-charcoal">{project.name}</h2>
                  <p class="mt-1 text-warm-gray">{project.description}</p>
                </div>
                <span class="text-sm text-warm-gray-light">{project.year}</span>
              </div>
              <!-- Tags -->
              <div class="mt-5 flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="rounded-full bg-cream px-3 py-1 text-xs font-medium text-warm-gray">
                    {tag}
                  </span>
                ))}
              </div>
              <!-- Arrow -->
              <div class="mt-6 flex items-center gap-2 text-sm font-semibold text-charcoal transition-colors group-hover:text-terracotta">
                View case study
                <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
