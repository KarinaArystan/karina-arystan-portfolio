<script>
  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbVideo = document.getElementById('lightbox-video') as HTMLVideoElement;
  const lbClose = document.getElementById('lightbox-close');

  if (lightbox && lbImg && lbVideo && lbClose) {
    // Click on any image in the article to open lightbox
    document.querySelectorAll('article img').forEach((img) => {
      if ((img as HTMLElement).dataset.noLightbox !== undefined) return;
      if ((img as HTMLElement).closest('[data-no-lightbox]')) return;
      (img as HTMLElement).style.cursor = 'zoom-in';
      img.addEventListener('click', () => {
        lbImg.src = (img as HTMLImageElement).src;
        lbImg.alt = (img as HTMLImageElement).alt;
        lbImg.classList.remove('hidden');
        lbVideo.classList.add('hidden');
        lbVideo.pause();
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    });

    // Click on any video in the article to open lightbox
    document.querySelectorAll('article video').forEach((vid) => {
      if ((vid as HTMLElement).dataset.noLightbox !== undefined) return;
      if ((vid as HTMLElement).closest('[data-no-lightbox]')) return;
      (vid as HTMLElement).style.cursor = 'zoom-in';
      vid.addEventListener('click', () => {
        const source = (vid as HTMLVideoElement).querySelector('source');
        if (source) {
          lbVideo.src = source.src;
        }
        lbVideo.classList.remove('hidden');
        lbImg.classList.add('hidden');
        lbVideo.play();
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    });

    // Close lightbox
    function closeLightbox() {
      lightbox!.classList.add('hidden');
      lightbox!.classList.remove('flex');
      lbVideo.pause();
      lbVideo.src = '';
      document.body.style.overflow = '';
    }

    lbClose.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) closeLightbox();
    });
  }
</script>

